<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ deck_title | e }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="{{ fonts_url }}" rel="stylesheet" />
  <style>
:root {
  --title-size: clamp(1.5rem, 5vw, 3.25rem);
  --h2-size: clamp(1.15rem, 3vw, 2rem);
  --h3-size: clamp(1rem, 2.5vw, 1.35rem);
  --body-size: clamp(0.8rem, 1.4vw, 1.05rem);
  --small-size: clamp(0.65rem, 1vw, 0.85rem);
  --slide-padding: clamp(1rem, 4vw, 3rem);
  --content-gap: clamp(0.5rem, 2vw, 1.5rem);
  --element-gap: clamp(0.25rem, 1vw, 0.75rem);
  {{ css_variables | safe }}
}

html, body { height: 100%; margin: 0; overflow-x: hidden; }
html { scroll-snap-type: y mandatory; scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  font-size: var(--body-size);
  line-height: 1.45;
  color: var(--color-ink);
  background: var(--color-bg);
}

body.theme-dark { background: var(--color-bg); color: var(--color-ink); }
body.theme-light { background: var(--color-bg); }

.slide {
  width: 100vw;
  height: 100vh;
  height: 100dvh;
  overflow: hidden;
  scroll-snap-align: start;
  display: flex;
  flex-direction: column;
  position: relative;
  box-sizing: border-box;
  background: var(--color-surface);
}

.slide-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  max-height: 100%;
  overflow: hidden;
  padding: var(--slide-padding);
  position: relative;
  z-index: 1;
}

.display { font-family: var(--font-display); }
.title-h1 { font-size: var(--title-size); line-height: 1.08; margin: 0 0 var(--element-gap); font-weight: 700; }
.subtitle { font-size: var(--h3-size); opacity: 0.92; margin: 0 0 var(--content-gap); max-width: 38ch; }
.meta-line, .deck-tag { font-size: var(--small-size); letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.85; margin: 0 0 0.35rem; }

/* Title slide */
.slide-title { background: var(--color-bg); padding: 0; }
.slide-title .slide-content { padding: 0; }
.slide-title-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  height: 100%;
  max-height: 100%;
  align-items: stretch;
}
.title-left {
  padding: var(--slide-padding);
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--color-primary-dark, var(--color-bg));
  color: var(--color-on-dark);
}
.theme-light .slide-title .title-left { color: var(--color-on-dark); }
.title-visual { min-height: 0; position: relative; }
.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.hero-img.cover { object-fit: cover; }
.hero-placeholder {
  width: 100%;
  height: 100%;
  min-height: 12rem;
  background: linear-gradient(145deg, var(--color-highlight), var(--color-surface));
  opacity: 0.7;
}

/* Header band (dark strip) */
.theme-band .slide-header-strip {
  flex-shrink: 0;
  background: var(--color-primary-dark, #0a0a0a);
  color: var(--color-on-dark);
  padding: clamp(0.5rem, 1.5vh, 0.85rem) var(--slide-padding);
}
.slide-header-inner { max-width: min(92vw, 1100px); margin: 0 auto; }
.kicker { font-size: var(--small-size); margin: 0 0 0.35rem; font-weight: 600; }
.action-title { font-size: var(--h2-size); line-height: 1.2; margin: 0; font-weight: 600; color: inherit; }
.action-title.solo { color: var(--color-ink); }

.theme-band .slide-content { background: var(--color-surface); color: var(--color-ink); }

/* Chapter */
.chapter-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--content-gap);
  align-items: center;
  height: 100%;
}
.chapter-num { font-size: clamp(3rem, 12vw, 7rem); line-height: 1; margin: 0; font-weight: 700; opacity: 0.25; }
.chapter-title { margin: 0.25rem 0; font-size: var(--title-size); }
.chapter-hook { margin: 0; max-width: 42ch; opacity: 0.9; }
.chapter-visual { min-height: 0; border-radius: clamp(4px, 1vw, 12px); overflow: hidden; max-height: min(72vh, 620px); }

/* SCQA */
.scqa-body { padding-top: clamp(0.5rem, 2vh, 1rem); }
.scqa-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--element-gap);
  max-width: min(96vw, 1100px);
  margin: 0 auto;
}
.scqa-card {
  padding: var(--content-gap);
  border-radius: clamp(4px, 1vw, 10px);
  background: var(--color-bg);
  border: 1px solid rgba(0,0,0,0.06);
}
.theme-dark .scqa-card { border-color: rgba(255,255,255,0.1); }
.scqa-answer { border-color: var(--color-accent); }
.scqa-label { font-weight: 800; font-size: var(--small-size); color: var(--color-accent); margin-right: 0.35rem; }
.scqa-text { margin: 0; font-size: var(--body-size); }
.source { font-size: var(--small-size); color: var(--color-muted); margin-top: auto; padding-top: var(--content-gap); max-width: min(92vw, 1100px); margin-left: auto; margin-right: auto; }

/* Hero split */
.hero-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: var(--content-gap);
  align-items: center;
  height: 100%;
}
.big-number { font-size: clamp(2.5rem, 8vw, 4.5rem); line-height: 1; margin: 0; font-weight: 800; }
.hero-label { font-size: var(--small-size); color: var(--color-muted); margin: 0.35rem 0 var(--content-gap); }
.hero-side { min-height: 0; max-height: min(70vh, 560px); border-radius: clamp(4px, 1vw, 12px); overflow: hidden; }

/* Exec summary */
.exec-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: var(--content-gap);
  align-items: center;
  height: 100%;
}
.exec-visual { max-height: min(68vh, 540px); border-radius: clamp(4px, 1vw, 12px); overflow: hidden; }

/* KPI */
.kpi-body { justify-content: center; gap: var(--content-gap); }
.kpi-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--content-gap);
  max-width: min(96vw, 1100px);
  margin: 0 auto;
  flex: 1;
  align-items: center;
}
.kpi-card {
  background: var(--color-bg);
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: clamp(6px, 1.2vw, 14px);
  padding: var(--content-gap);
  text-align: center;
}
.theme-dark .kpi-card { border-color: rgba(255,255,255,0.12); }
.kpi-highlight { border-color: var(--color-accent); box-shadow: 0 0 0 1px var(--color-accent); }
.kpi-value { font-size: clamp(1.75rem, 5vw, 3rem); margin: 0; line-height: 1.1; color: var(--color-primary-dark, var(--color-ink)); }
.kpi-highlight .kpi-value { color: var(--color-accent); }
.kpi-label { font-size: var(--small-size); color: var(--color-muted); margin: 0.5rem 0 0; white-space: pre-line; }

/* Two column */
.two-col-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--content-gap);
  align-items: start;
  height: 100%;
  max-width: min(96vw, 1150px);
  margin: 0 auto;
}
.two-col-grid .source { grid-column: 1 / -1; }
.right-text-box {
  background: var(--color-bg);
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: clamp(6px, 1vw, 12px);
  padding: var(--content-gap);
  max-height: min(58vh, 480px);
  overflow: hidden;
}
.mini-chart-wrap { max-height: min(52vh, 420px); }

/* Chart slide */
.chart-layout {
  display: grid;
  grid-template-columns: 1.25fr 0.45fr;
  gap: var(--content-gap);
  align-items: stretch;
  height: 100%;
  max-width: min(98vw, 1180px);
  margin: 0 auto;
}
.chart-svg-wrap { max-height: min(56vh, 480px); overflow: hidden; }
.chart-svg-wrap svg { width: 100%; height: auto; max-height: min(56vh, 480px); }
.insight-thumb { width: 100%; max-height: min(40vh, 280px); object-fit: cover; border-radius: 8px; }

/* Comparison */
.compare-body { max-width: min(96vw, 1100px); margin: 0 auto; }
.table-wrap { overflow: hidden; max-height: min(58vh, 520px); }
.compare-table { width: 100%; border-collapse: collapse; font-size: var(--small-size); }
.compare-table th, .compare-table td {
  padding: 0.5rem 0.65rem;
  border: 1px solid rgba(0,0,0,0.1);
  text-align: left;
}
.theme-dark .compare-table th, .theme-dark .compare-table td { border-color: rgba(255,255,255,0.12); }
.compare-table thead th { background: var(--color-primary-dark); color: var(--color-on-dark); }
.compare-table .col-rec { background: var(--color-accent); color: #0a0a0a; }

/* Timeline */
.timeline-body { max-width: min(96vw, 1100px); margin: 0 auto; gap: var(--content-gap); }
.timeline-track {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--element-gap);
  position: relative;
  padding-top: 0.5rem;
  flex: 1;
  max-height: min(50vh, 400px);
}
.timeline-track::before {
  content: "";
  position: absolute;
  left: 4%; right: 4%; top: 42%;
  height: 3px;
  background: var(--color-muted);
  opacity: 0.35;
}
.milestone { flex: 1; text-align: center; position: relative; z-index: 1; min-width: 0; }
.milestone-when { font-size: var(--small-size); color: var(--color-muted); margin: 0 0 0.25rem; }
.milestone-dot {
  display: inline-block;
  width: clamp(10px, 2vw, 14px);
  height: clamp(10px, 2vw, 14px);
  border-radius: 50%;
  background: var(--color-primary-dark);
  margin: 0.25rem 0;
}
.milestone-hi .milestone-dot { background: var(--color-accent); }
.milestone-label { font-size: var(--small-size); font-weight: 600; margin: 0.25rem 0 0; }
.timeline-thumb img { max-height: min(22vh, 180px); border-radius: 8px; }

/* Image right */
.img-right-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--content-gap);
  height: 100%;
  max-width: min(96vw, 1150px);
  margin: 0 auto;
  align-items: center;
}
.irr-right { max-height: min(68vh, 560px); border-radius: clamp(6px, 1vw, 12px); overflow: hidden; }

/* Closing */
.slide-closing { background: var(--color-primary-dark); color: var(--color-on-dark); }
.closing-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: var(--content-gap);
  height: 100%;
  max-width: min(96vw, 1100px);
  margin: 0 auto;
  align-items: center;
}
.closing-title { font-size: var(--h2-size); margin: 0 0 var(--content-gap); color: var(--color-on-dark); }
.closing-sub { font-size: var(--small-size); text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); margin: 0 0 0.5rem; }
.next-steps { list-style: none; padding: 0; margin: 0; font-size: var(--body-size); }
.next-steps li { margin-bottom: 0.5rem; display: flex; flex-wrap: wrap; gap: 0.35rem 0.75rem; align-items: baseline; }
.ns-meta { font-size: var(--small-size); opacity: 0.8; }
.next-review { font-size: var(--small-size); margin-top: var(--content-gap); opacity: 0.85; }
.closing-visual { max-height: min(70vh, 520px); border-radius: clamp(6px, 1vw, 12px); overflow: hidden; }

.bullet-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--element-gap); max-width: 52ch; }
.bullet-list li { position: relative; padding-left: 1.1rem; }
.bullet-list li::before { content: "▸"; position: absolute; left: 0; color: var(--color-accent); font-weight: 700; }

.reveal { opacity: 0; transform: translateY(12px); transition: opacity 0.45s ease, transform 0.45s ease; }
.reveal.is-visible { opacity: 1; transform: none; }

#deck-nav {
  position: fixed;
  right: clamp(0.5rem, 2vw, 1rem);
  bottom: clamp(0.5rem, 2vh, 1rem);
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: var(--small-size);
  background: rgba(0,0,0,0.55);
  color: #fff;
  padding: 0.35rem 0.65rem;
  border-radius: 999px;
  font-variant-numeric: tabular-nums;
}
body.theme-light #deck-nav { background: rgba(15,15,15,0.75); }

@media (max-height: 700px) {
  :root {
    --slide-padding: clamp(0.75rem, 3vw, 2rem);
    --title-size: clamp(1.25rem, 4.5vw, 2.5rem);
  }
}
@media (max-width: 720px) {
  .slide-title-grid, .chapter-grid, .hero-grid, .exec-grid, .two-col-grid, .chart-layout, .img-right-grid, .closing-grid {
    grid-template-columns: 1fr;
  }
  .title-visual { min-height: 40vh; }
  .kpi-row { grid-template-columns: 1fr; }
  .scqa-grid { grid-template-columns: 1fr; }
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.15s !important;
  }
  html { scroll-behavior: auto; }
  .reveal { opacity: 1; transform: none; }
}

{{ signature_css | safe }}
  </style>
</head>
<body class="{{ body_class }}">
  <main id="deck" aria-label="{{ deck_title | e }}">
    {{ inner_html | safe }}
  </main>
  <nav id="deck-nav" aria-live="polite"><span id="nav-idx">1</span> / <span id="nav-total">{{ slide_count }}</span></nav>
  <script>
(function () {
  const slides = Array.from(document.querySelectorAll('.slide'));
  const idxEl = document.getElementById('nav-idx');
  const totalEl = document.getElementById('nav-total');
  totalEl.textContent = String(slides.length);

  function currentIndex() {
    const h = window.innerHeight || 1;
    return Math.round(window.scrollY / h);
  }

  function go(i) {
    const h = window.innerHeight || 1;
    const clamped = Math.max(0, Math.min(slides.length - 1, i));
    window.scrollTo({ top: clamped * h, behavior: 'auto' });
  }

  function updateNav() {
    idxEl.textContent = String(currentIndex() + 1);
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  window.addEventListener('resize', updateNav);

  window.addEventListener('keydown', function (e) {
    const i = currentIndex();
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ' || e.key === 'PageDown') {
      e.preventDefault();
      go(i + 1);
    } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp' || e.key === 'PageUp') {
      e.preventDefault();
      go(i - 1);
    } else if (e.key === 'Home') { e.preventDefault(); go(0); }
    else if (e.key === 'End') { e.preventDefault(); go(slides.length - 1); }
  });

  let wheelLock = false;
  window.addEventListener('wheel', function (e) {
    if (wheelLock) return;
    const i = currentIndex();
    if (e.deltaY > 30) { go(i + 1); wheelLock = true; setTimeout(function () { wheelLock = false; }, 550); e.preventDefault(); }
    else if (e.deltaY < -30) { go(i - 1); wheelLock = true; setTimeout(function () { wheelLock = false; }, 550); e.preventDefault(); }
  }, { passive: false });

  let touchY = null;
  window.addEventListener('touchstart', function (e) {
    touchY = e.changedTouches[0].clientY;
  }, { passive: true });
  window.addEventListener('touchend', function (e) {
    if (touchY == null) return;
    const dy = touchY - e.changedTouches[0].clientY;
    const i = currentIndex();
    if (dy > 50) go(i + 1);
    else if (dy < -50) go(i - 1);
    touchY = null;
  }, { passive: true });

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(function (ents) {
      ents.forEach(function (en) {
        if (en.isIntersecting) en.target.classList.add('is-visible');
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
  } else {
    document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('is-visible'); });
  }

  updateNav();
})();
  </script>
</body>
</html>
