{% import "macros.j2" as m %}
<section class="slide slide-title theme-band" id="slide-{{ slide_index }}" aria-label="Slide {{ slide_index + 1 }}">
  <div class="preset-signature" aria-hidden="true"></div>
  <div class="slide-content slide-title-grid">
    <div class="title-left reveal">
      {% if slide.deck_tag %}<p class="deck-tag">{{ slide.deck_tag }}</p>{% endif %}
      <h1 class="display title-h1">{{ slide.title }}</h1>
      {% if slide.subtitle %}<p class="subtitle">{{ slide.subtitle }}</p>{% endif %}
      {% if slide.date %}<p class="meta-line">{{ slide.date }}</p>{% endif %}
      {% if deck.author %}<p class="meta-line">{{ deck.author }}</p>{% endif %}
    </div>
    <div class="title-visual reveal">
      {% if slide.image_path %}
      <img class="hero-img" src="{{ asset(slide.image_path) }}" alt="" loading="lazy" width="800" height="1000" />
      {% else %}
      <div class="hero-placeholder" aria-hidden="true"></div>
      {% endif %}
    </div>
  </div>
</section>
