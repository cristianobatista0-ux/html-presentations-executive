{% import "macros.j2" as m %}
<section class="slide slide-chapter" id="slide-{{ slide_index }}">
  <div class="preset-signature" aria-hidden="true"></div>
  <div class="slide-content chapter-grid">
    <div class="chapter-copy reveal">
      {% if slide.chapter_num %}<p class="chapter-num">{{ slide.chapter_num }}</p>{% endif %}
      {% if slide.chapter_title %}<h2 class="display chapter-title">{{ slide.chapter_title }}</h2>{% endif %}
      {% if slide.hook %}<p class="chapter-hook">{{ slide.hook }}</p>{% endif %}
    </div>
    <div class="chapter-visual reveal">
      {% if slide.image_path %}
      <img class="hero-img cover" src="{{ asset(slide.image_path) }}" alt="" loading="lazy" />
      {% else %}
      <div class="hero-placeholder wide"></div>
      {% endif %}
    </div>
  </div>
</section>
