{% import "macros.j2" as m %}
<section class="slide slide-timeline theme-band" id="slide-{{ slide_index }}">
  <div class="preset-signature" aria-hidden="true"></div>
  <div class="slide-header-strip"><div class="slide-header-inner">{{ m.kicker_title(slide) }}</div></div>
  <div class="slide-content timeline-body">
    <div class="timeline-track reveal">
      {% for m in slide.milestones %}
      <div class="milestone {% if m.highlight %}milestone-hi{% endif %}">
        <p class="milestone-when">{{ m.when }}</p>
        <span class="milestone-dot" aria-hidden="true"></span>
        <p class="milestone-label">{{ m.label }}</p>
      </div>
      {% endfor %}
    </div>
    {% if slide.image_path %}
    <div class="timeline-thumb reveal"><img src="{{ asset(slide.image_path) }}" alt="" loading="lazy" /></div>
    {% endif %}
    {{ m.source_foot(slide) }}
  </div>
</section>
