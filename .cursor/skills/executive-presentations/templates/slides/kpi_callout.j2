{% import "macros.j2" as m %}
<section class="slide slide-kpi theme-band" id="slide-{{ slide_index }}">
  <div class="preset-signature" aria-hidden="true"></div>
  <div class="slide-header-strip"><div class="slide-header-inner">{{ m.kicker_title(slide) }}</div></div>
  <div class="slide-content kpi-body">
    <div class="kpi-row">
      {% for k in slide.kpis[:3] %}
      <article class="kpi-card reveal {% if k.highlight %}kpi-highlight{% endif %}">
        <p class="kpi-value display">{{ k.value }}</p>
        <p class="kpi-label">{{ k.label | replace('\n', '<br/>') | safe }}</p>
      </article>
      {% endfor %}
    </div>
    {{ m.source_foot(slide) }}
  </div>
</section>
