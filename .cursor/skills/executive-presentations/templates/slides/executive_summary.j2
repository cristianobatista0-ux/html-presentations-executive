{% import "macros.j2" as m %}
<section class="slide slide-exec theme-band" id="slide-{{ slide_index }}">
  <div class="preset-signature" aria-hidden="true"></div>
  <div class="slide-header-strip"><div class="slide-header-inner">{{ m.kicker_title(slide) }}</div></div>
  <div class="slide-content exec-grid">
    <div class="exec-text reveal">
      {% if slide.action_title %}<h2 class="action-title solo">{{ slide.action_title }}</h2>{% endif %}
      {% if slide.bullets %}
      <ul class="bullet-list tight">
        {% for b in slide.bullets %}<li>{{ b }}</li>{% endfor %}
      </ul>
      {% endif %}
      {{ m.source_foot(slide) }}
    </div>
    <div class="exec-visual reveal">
      {% if slide.image_path %}
      <img class="hero-img cover" src="{{ asset(slide.image_path) }}" alt="" loading="lazy" />
      {% elif slide.image_url %}
      <img class="hero-img cover" src="{{ slide.image_url }}" alt="" loading="lazy" />
      {% else %}<div class="hero-placeholder"></div>{% endif %}
    </div>
  </div>
</section>
