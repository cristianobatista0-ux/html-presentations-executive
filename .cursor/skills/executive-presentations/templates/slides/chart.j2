{% import "macros.j2" as m %}
<section class="slide slide-chart theme-band" id="slide-{{ slide_index }}">
  <div class="preset-signature" aria-hidden="true"></div>
  <div class="slide-header-strip"><div class="slide-header-inner">{{ m.kicker_title(slide) }}</div></div>
  <div class="slide-content chart-layout">
    <div class="chart-main reveal">
      <div class="chart-svg-wrap">{{ chart_svg(slide.chart) | safe }}</div>
    </div>
    <div class="chart-side reveal">
      {% set ip = slide.insight_image_path or slide.image_path %}
      {% if ip %}
      <img class="insight-thumb" src="{{ asset(ip) }}" alt="" loading="lazy" />
      {% endif %}
    </div>
    {{ m.source_foot(slide) }}
  </div>
</section>
