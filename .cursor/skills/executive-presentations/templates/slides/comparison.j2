{% import "macros.j2" as m %}
<section class="slide slide-compare theme-band" id="slide-{{ slide_index }}">
  <div class="preset-signature" aria-hidden="true"></div>
  <div class="slide-header-strip"><div class="slide-header-inner">{{ m.kicker_title(slide) }}</div></div>
  <div class="slide-content compare-body">
    <div class="table-wrap reveal">
      <table class="compare-table">
        <thead>
          <tr>
            <th scope="col"></th>
            {% for c in slide.columns %}
            <th scope="col" class="{% if c.recommended %}col-rec{% endif %}">{{ c.name }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for r in slide.rows %}
          <tr>
            <th scope="row">{{ r.dimension }}</th>
            {% for v in r['values'] %}
            <td>{{ v }}</td>
            {% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {{ m.source_foot(slide) }}
  </div>
</section>
