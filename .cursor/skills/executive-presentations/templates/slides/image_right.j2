{% import "macros.j2" as m %}
<section class="slide slide-img-right theme-band" id="slide-{{ slide_index }}">
  <div class="preset-signature" aria-hidden="true"></div>
  <div class="slide-header-strip"><div class="slide-header-inner">{{ m.kicker_title(slide) }}</div></div>
  <div class="slide-content img-right-grid">
    <div class="irr-left reveal">
      <ul class="bullet-list">
        {% for b in slide.bullets %}<li>{{ b }}</li>{% endfor %}
      </ul>
    </div>
    <div class="irr-right reveal">
      {% if slide.image_path %}
      <img class="hero-img cover" src="{{ asset(slide.image_path) }}" alt="" loading="lazy" />
      {% else %}<div class="hero-placeholder"></div>{% endif %}
    </div>
    {{ m.source_foot(slide) }}
  </div>
</section>
