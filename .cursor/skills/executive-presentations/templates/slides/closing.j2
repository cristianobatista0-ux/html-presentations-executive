<section class="slide slide-closing" id="slide-{{ slide_index }}">
  <div class="preset-signature" aria-hidden="true"></div>
  <div class="slide-content closing-grid">
    <div class="closing-copy reveal">
      {% if slide.action_title %}<h2 class="closing-title display">{{ slide.action_title }}</h2>{% endif %}
      <h3 class="closing-sub">Próximos passos</h3>
      <ul class="next-steps">
        {% for s in slide.next_steps %}
        <li><span class="ns-action">{{ s.action }}</span>{% if s.owner %}<span class="ns-meta">{{ s.owner }}</span>{% endif %}{% if s.due %}<span class="ns-meta">{{ s.due }}</span>{% endif %}</li>
        {% endfor %}
      </ul>
      {% if slide.next_review %}<p class="next-review">{{ slide.next_review }}</p>{% endif %}
    </div>
    <div class="closing-visual reveal">
      {% if slide.image_path %}
      <img class="hero-img cover" src="{{ asset(slide.image_path) }}" alt="" loading="lazy" />
      {% else %}<div class="hero-placeholder"></div>{% endif %}
    </div>
  </div>
</section>
